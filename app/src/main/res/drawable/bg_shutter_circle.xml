<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- outer subtle ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#F5F1E8" />
            <stroke
                android:width="1dp"
                android:color="#D8D0C2" />
        </shape>
    </item>

    <!-- gap + inner ring -->
    <item
        android:top="5dp"
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp">
        <shape android:shape="oval">
            <solid android:color="#F1EFE8" />
            <stroke
                android:width="2dp"
                android:color="#8F8A82" />
        </shape>
    </item>

</layer-list>